---
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>Packing Checklist — Cali 2026</title>
    <meta name="description" content="Everything we need to pack for the trip." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="page">
      <header class="page-header">
        <a href={import.meta.env.BASE_URL} class="back-link">← Back to home</a>
        <h1>Packing Checklist</h1>
        <p class="subtitle">Everything we need for the trip — from Half Dome to the coast.</p>
      </header>

      <main class="checklist">

        <section>
          <h2>Documents & Permits</h2>
          <ul>
            <li>Half Dome permits (print + phone)</li>
            <li>Passport / ID</li>
            <li>Rental car confirmation</li>
            <li>Hotel & campsite reservations</li>
            <li>Travel insurance info</li>
            <li>America the Beautiful pass (optional — saves on park entry)</li>
          </ul>
        </section>

        <section>
          <h2>Hiking — Half Dome Essentials</h2>
          <ul>
            <li>Hiking boots (broken in — no new shoes)</li>
            <li>Trekking poles</li>
            <li>Gloves for the cables (or pick up the shared ones at the base)</li>
            <li>Headlamp + spare batteries</li>
            <li>Hydration pack or water bottles (3L minimum)</li>
            <li>Water filter or purification tablets</li>
            <li>High-calorie snacks (bars, nuts, jerky)</li>
            <li>Lunch for the summit</li>
            <li>Blister kit (moleskin, bandages)</li>
            <li>Sunscreen SPF 50+</li>
            <li>Sunglasses</li>
            <li>Trekking hat or cap</li>
          </ul>
        </section>

        <section>
          <h2>Clothing</h2>
          <ul>
            <li>Moisture-wicking base layers (×3)</li>
            <li>Fleece or mid-layer (cold at summit and early mornings)</li>
            <li>Rain jacket / windbreaker</li>
            <li>Hiking pants or shorts</li>
            <li>Casual clothes for non-hike days</li>
            <li>Warm layer for evenings in the valley</li>
            <li>Swimwear</li>
            <li>Comfortable walking shoes (non-hiking)</li>
            <li>Sandals or flip flops</li>
            <li>Merino wool or hiking socks (×4 pairs minimum)</li>
          </ul>
        </section>

        <section>
          <h2>Camping & Lodging</h2>
          <ul>
            <li>Sleeping bag liner (canvas tent cabins can be cold)</li>
            <li>Small towel (quick-dry)</li>
            <li>Earplugs (Curry Village can be noisy)</li>
            <li>Eye mask</li>
            <li>Portable charger / power bank</li>
            <li>Universal outlet adapter (if needed)</li>
          </ul>
        </section>

        <section>
          <h2>Toiletries & Health</h2>
          <ul>
            <li>Ibuprofen / paracetamol</li>
            <li>Blister treatment</li>
            <li>Electrolyte tablets or powder</li>
            <li>Bug repellent</li>
            <li>Lip balm with SPF</li>
            <li>Hand sanitizer</li>
            <li>Basic first aid kit</li>
            <li>Any prescription medication (pack extra)</li>
          </ul>
        </section>

        <section>
          <h2>Tech & Navigation</h2>
          <ul>
            <li>Phone + charging cable</li>
            <li>Offline maps downloaded (Google Maps / AllTrails for Yosemite)</li>
            <li>Camera (phone is fine — but pack it charged)</li>
            <li>Car charger / adapter</li>
            <li>Headphones</li>
            <li>E-SIM or international plan activated</li>
          </ul>
        </section>

        <section>
          <h2>Car & Road Trip</h2>
          <ul>
            <li>Snacks for the drive</li>
            <li>Reusable water bottles</li>
            <li>Trash bag for the car</li>
            <li>Sunshade for windshield</li>
            <li>Paper map of California (cell service in parks is spotty)</li>
          </ul>
        </section>

      </main>
    </div>
  </body>
  <script>
    const STORAGE_KEY = 'packing-checked-v1';

    function loadChecked(): Record<string, boolean> {
      try {
        return JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
      } catch {
        return {};
      }
    }

    function saveChecked(state: Record<string, boolean>) {
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
      } catch {}
    }

    const state = loadChecked();

    document.querySelectorAll<HTMLLIElement>('.checklist li').forEach((li) => {
      const key = li.textContent?.trim() ?? '';
      if (!key) return;

      li.setAttribute('role', 'checkbox');
      li.setAttribute('tabindex', '0');
      li.setAttribute('aria-checked', state[key] ? 'true' : 'false');
      if (state[key]) li.classList.add('checked');

      function toggle() {
        const checked = li.classList.toggle('checked');
        li.setAttribute('aria-checked', String(checked));
        if (checked) {
          state[key] = true;
        } else {
          delete state[key];
        }
        saveChecked(state);
      }

      li.addEventListener('click', toggle);
      li.addEventListener('keydown', (e) => {
        if (e.key === ' ' || e.key === 'Enter') { e.preventDefault(); toggle(); }
      });
    });
  </script>
</html>

<style>
  body {
    margin: 0;
    background: #fff;
    font-family: 'Inter', system-ui, sans-serif;
    -webkit-font-smoothing: antialiased;
    color: #222;
  }
  .page {
    max-width: 680px;
    margin: 0 auto;
    padding: 2.5rem 2rem 5rem;
  }
  .page-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 2px solid #f0f0f0;
  }
  .back-link {
    display: inline-block;
    font-size: 0.875rem;
    color: #4e7a56;
    text-decoration: none;
    margin-bottom: 1.25rem;
  }
  .back-link:hover { text-decoration: underline; }
  h1 {
    font-size: 2rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
    color: #111;
    line-height: 1.2;
  }
  .subtitle {
    font-size: 0.95rem;
    color: #666;
    margin: 0;
  }
  section {
    margin-bottom: 2.25rem;
  }
  h2 {
    font-size: 1.1rem;
    font-weight: 700;
    color: #111;
    margin: 0 0 0.75rem;
    padding-bottom: 0.4rem;
    border-bottom: 2px solid #f0f0f0;
  }
  ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  li {
    padding: 0.5rem 0.25rem;
    font-size: 0.925rem;
    color: #333;
    border-bottom: 1px solid #f5f5f5;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    line-height: 1.5;
    cursor: pointer;
    user-select: none;
    border-radius: 6px;
    transition: background 0.12s;
  }
  li::before {
    content: '';
    width: 16px;
    height: 16px;
    min-width: 16px;
    border: 1.5px solid #ccc;
    border-radius: 4px;
    display: inline-block;
    flex-shrink: 0;
    transition: background 0.15s, border-color 0.15s;
  }
  li.checked::before {
    background: #4e7a56;
    border-color: #4e7a56;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 12 10' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M1 5l3.5 3.5L11 1' stroke='%23fff' stroke-width='1.8' fill='none' stroke-linecap='round' stroke-linejoin='round'/%3E%3C/svg%3E");
    background-repeat: no-repeat;
    background-position: center;
    background-size: 10px 8px;
  }
  li.checked {
    color: #999;
    text-decoration: line-through;
    text-decoration-color: #bbb;
  }
  @media (max-width: 600px) {
    .page { padding: 1.5rem 1.25rem 4rem; }
    h1 { font-size: 1.6rem; }
  }
</style>
