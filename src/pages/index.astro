---
import { getCollection } from 'astro:content';
import '../styles/global.css';

const days = (await getCollection('days')).sort((a, b) =>
  a.id.localeCompare(b.id)
);

---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cali 2026 — Road Trip</title>
    <meta name="description" content="Our California road trip — day by day." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#154753">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=optional" rel="stylesheet" />
  </head>
  <body class="index-page">
    <header class="site-header">
      <img src={`${import.meta.env.BASE_URL}images/cali.jpg`} alt="" class="header-bg" aria-hidden="true" />
      <div class="header-overlay"></div>
      <div class="header-inner">
        <h1 class="site-title">Cali 2026</h1>
        <p class="site-tagline">From High Sierra to Pacific Coast, discover California's finest.</p>
      </div>
    </header>

    <div class="content-wrap">
    <main class="index-main">
      {/* To add a full-route map: paste your Google Maps embed URL as the src below, then uncomment */}
      {/*
      <section class="overview-map">
        <iframe
          src="https://www.google.com/maps/embed?pb=..."
          title="Full trip route"
          loading="lazy"
          allowfullscreen
        ></iframe>
      </section>
      */}

      <div class="packing-banner-wrap" id="packing-banner">
        <a href={`${import.meta.env.BASE_URL}packing`} class="packing-banner">
          <div class="packing-banner-text">
            <span class="packing-banner-title">🧳 Packing Checklist <span class="packing-chevron">›</span></span>
            <span class="packing-banner-sub">Everything we need for the trip.</span>
          </div>
        </a>
        <button class="packing-banner-dismiss" id="packing-dismiss" aria-label="Dismiss">✕</button>
      </div>

      <section class="days-grid">
        <h2 class="section-heading">The Itinerary</h2>
        <div class="grid">
          {days.map((day) => (
            <a href={`${import.meta.env.BASE_URL}days/${day.id}`} class="day-card">
              {day.data.heroImage ? (
                <div class="card-image">
                  <img src={`${import.meta.env.BASE_URL}${day.data.heroImage}`} alt={day.data.title} loading="lazy" />
                </div>
              ) : (
                <div class="card-image placeholder"></div>
              )}
              <div class="card-body">
                <p class="card-date">{day.data.date}</p>
                <h3 class="card-title">{day.data.title}</h3>
                <p class="card-summary">{day.data.summary}</p>
              </div>
            </a>
          ))}
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <p>Made with Astro · {new Date().getFullYear()}</p>
    </footer>
    </div>
  <script>
    const banner = document.getElementById('packing-banner');
    if (localStorage.getItem('packing-banner-dismissed') === '1') {
      banner?.classList.add('hidden');
    }
    document.getElementById('packing-dismiss')?.addEventListener('click', () => {
      const hide = confirm('Hide this banner permanently?');
      if (hide) {
        banner?.classList.add('hidden');
        localStorage.setItem('packing-banner-dismissed', '1');
      }
    });
  </script>
  <script>
    document.querySelectorAll('.card-image img').forEach((img) => {
      const el = img as HTMLImageElement;
      if (el.complete) {
        el.classList.add('loaded');
      } else {
        el.addEventListener('load', () => el.classList.add('loaded'));
      }
    });
  </script>
  </body>
</html>

<style>
  .index-page {
    background: #154753;
    min-height: 100dvh;
    overscroll-behavior-y: none;
  }
  .site-header {
    position: relative;
    color: #fff;
    padding: 6rem 2rem;
    text-align: center;
    overflow: hidden;
    background: #154753;
  }
  .header-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .header-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
  }
  .header-inner {
    position: relative;
    z-index: 1;
    max-width: 680px;
    margin: 0 auto;
}
  .site-title {
    font-size: 3rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
    letter-spacing: -0.02em;
  }
  .site-tagline {
    font-size: 1rem;
    font-weight: 500;
    margin: 0;
  }
  .content-wrap {
    background: #fff;
  }
  .index-main {
    max-width: 1000px;
    margin: 0 auto;
    padding: 1.5rem 2rem 2rem;
  }
  .overview-map {
    width: 100%;
    height: 400px;
    margin-bottom: 3rem;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid #e5e5e5;
  }
  .overview-map iframe {
    width: 100%;
    height: 100%;
    border: none;
  }
  .packing-banner-wrap {
    position: relative;
    margin-bottom: 1rem;
  }
  .packing-banner-wrap.hidden {
    display: none;
  }
  .packing-banner-dismiss {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    background: #ddeee1;
    border: none;
    font-size: 0.65rem;
    color: #4e7a56;
    cursor: pointer;
    width: 1.25rem;
    height: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    line-height: 1;
  }
  .packing-banner-dismiss:hover { background: #c8e0cd; }
  .packing-banner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: #eef5f0;
    border: 1px solid #c8e0cd;
    border-radius: 12px;
    padding: 1rem 1.25rem;
    text-decoration: none;
    color: inherit;
    transition: background 0.15s;
  }
  .packing-banner:hover { background: #e2f0e7; }
  .packing-banner-text {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .packing-banner-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: #2a5c36;
  }
  .packing-chevron {
    font-size: 1rem;
    color: #4e7a56;
    opacity: 0.7;
  }
  .packing-banner-sub {
    font-size: 0.8rem;
    color: #5a7f61;
  }
  .section-heading {
    font-size: 1.4rem;
    font-weight: 600;
    color: #111;
    margin: 0 0 1rem;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }
  .day-card {
    display: flex;
    flex-direction: column;
    border: 1px solid #e8e8e8;
    border-radius: 10px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  @media (hover: hover) {
    .day-card:hover {
      box-shadow: 0 4px 20px rgba(0,0,0,0.1);
      transform: translateY(-2px);
    }
  }
  .card-image {
    aspect-ratio: 3 / 2;
    overflow: hidden;
    background: #e8e8e8;
  }
  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 0;
    transition: opacity 0.3s ease, transform 0.3s;
  }
  .card-image img.loaded {
    opacity: 1;
  }
  @media (hover: hover) {
    .day-card:hover .card-image img { transform: scale(1.04); }
  }
  .card-image.placeholder {
    background: #e8e8e8;
  }
  .card-body {
    padding: 1rem 1.25rem 1.25rem;
  }
  .card-date {
    font-size: 0.78rem;
    color: #888;
    margin: 0 0 0.3rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .card-title {
    font-size: 1rem;
    font-weight: 600;
    color: #111;
    margin: 0 0 0.5rem;
    line-height: 1.3;
  }
  .card-summary {
    font-size: 0.875rem;
    color: #555;
    margin: 0;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .site-footer {
    text-align: center;
    padding: 2rem;
    font-size: 0.8rem;
    color: #aaa;
    border-top: 1px solid #eee;
  }
  @media (max-width: 600px) {
    .site-title { font-size: 2rem; }
    .grid { grid-template-columns: 1fr; }
    .site-header {
      padding: 3rem 2rem;
      display: flex;
      align-items: center;
      justify-content: center;
    }
  }
</style>
