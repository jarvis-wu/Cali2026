---
import Sidebar from '../components/Sidebar.astro';
import DayNav from '../components/DayNav.astro';
import '../styles/global.css';

interface DayEntry {
  id: string;
  data: { title: string };
}
interface Props {
  title: string;
  date: string;
  heroImage?: string;
  summary: string;
  slug: string;
  prev?: DayEntry;
  next?: DayEntry;
}
const { title, date, heroImage, summary, slug, prev, next } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>{title} — Cali 2026</title>
    <meta name="description" content={summary} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <!-- Mobile top bar (hidden on desktop) -->
    <div class="mobile-bar">
      <div class="mobile-bar-inner">
      <div class="mobile-bar-left">
        <button class="bar-btn sidebar-toggle" aria-label="Toggle navigation" aria-expanded="false">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
        <a href={import.meta.env.BASE_URL} class="bar-btn bar-home" aria-label="Home">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
            <polyline points="9 22 9 12 15 12 15 22"/>
          </svg>
        </a>
      </div>
      <div class="mobile-bar-right">
        {prev ? (
          <a href={`${import.meta.env.BASE_URL}days/${prev.id}`} class="bar-btn" aria-label={`Previous: ${prev.data.title}`}>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="15 18 9 12 15 6"/>
            </svg>
          </a>
        ) : (
          <span class="bar-btn bar-btn-disabled" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="15 18 9 12 15 6"/>
            </svg>
          </span>
        )}
        {next ? (
          <a href={`${import.meta.env.BASE_URL}days/${next.id}`} class="bar-btn" aria-label={`Next: ${next.data.title}`}>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </a>
        ) : (
          <span class="bar-btn bar-btn-disabled" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </span>
        )}
      </div>
      </div>
    </div>

    <div class="app-shell">
      <Sidebar currentSlug={slug} />

      <main class="main-content">
        {heroImage && (
          <div class="hero-image">
            <img src={`${import.meta.env.BASE_URL}${heroImage}`} alt={title} />
          </div>
        )}

        <article class:list={['prose', { 'has-hero': heroImage }]}>
          <header class="day-header">
            <h1>{title}</h1>
            <div class="day-meta">
              <span class="meta-item">{date}</span>
            </div>
          </header>

          <slot />

          <DayNav prev={prev} next={next} />
        </article>
      </main>
    </div>

    <script>
      const toggle = document.querySelector('.sidebar-toggle') as HTMLButtonElement;
      const sidebar = document.querySelector('.sidebar') as HTMLElement;

      function setSidebarOpen(open: boolean) {
        sidebar.classList.toggle('open', open);
        toggle.setAttribute('aria-expanded', String(open));
      }

      toggle?.addEventListener('click', () => {
        setSidebarOpen(!sidebar.classList.contains('open'));
      });
      // Close sidebar when clicking outside
      document.addEventListener('click', (e) => {
        if (sidebar.classList.contains('open') &&
            !sidebar.contains(e.target as Node) &&
            !toggle.contains(e.target as Node)) {
          setSidebarOpen(false);
        }
      });
    </script>
  </body>
</html>

<style>
  .mobile-bar {
    display: none;
  }

  .app-shell {
    display: flex;
    min-height: 100vh;
  }
  .main-content {
    flex: 1;
    min-width: 0;
    overflow: auto;
  }
  .hero-image {
    width: 100%;
    height: 420px;
    overflow: hidden;
  }
  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .prose {
    max-width: 740px;
    margin: 0 auto;
    padding: 2.5rem 2rem 4rem;
  }
  .day-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 2px solid #f0f0f0;
  }
  .day-header h1 {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.2;
    color: #111;
    margin: 0 0 0.75rem;
  }
  .day-meta {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
  }
  .meta-item {
    font-size: 0.9rem;
    color: #666;
  }

  @media (max-width: 768px) {
    .mobile-bar {
      display: block;
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      background: #fff;
      border-bottom: 1px solid #e8e8e8;
      /* push content below the notch */
      padding-top: env(safe-area-inset-top);
    }
    .mobile-bar-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 52px;
      padding: 0 0.5rem;
    }
    .mobile-bar-left,
    .mobile-bar-right {
      display: flex;
      align-items: center;
      gap: 0.25rem;
    }
    .bar-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 40px;
      border-radius: 8px;
      border: none;
      background: transparent;
      color: #333;
      cursor: pointer;
      text-decoration: none;
      -webkit-tap-highlight-color: transparent;
    }
    .bar-btn:active { background: #f0f0f0; }
    .bar-btn-disabled {
      opacity: 0.25;
      pointer-events: none;
    }

    .hero-image {
      height: 260px;
      margin-top: calc(env(safe-area-inset-top) + 52px);
    }
    .prose {
      /* when no hero image, clear the fixed bar */
      padding: calc(env(safe-area-inset-top) + 52px + 1.5rem) 1.25rem 3rem;
    }
    .prose.has-hero {
      padding-top: 2rem;
    }
    .day-header h1 { font-size: 1.6rem; }
  }
</style>
