---
interface Props {
  src: string;
  title?: string;
  height?: number;
}
const { src, title = 'Map', height = 450 } = Astro.props;
---

<div class="map-embed" style={`--map-height: ${height}px`}>
  <iframe
    src={src}
    title={title}
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
    allowfullscreen
  ></iframe>
</div>

<style>
  .map-embed {
    width: 100%;
    height: var(--map-height, 450px);
    margin: 2rem 0;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid #e5e5e5;
  }
  iframe {
    width: 100%;
    height: 100%;
    border: none;
  }
</style>
