---
import { getCollection } from 'astro:content';

interface Props {
  currentSlug?: string;
}
const { currentSlug } = Astro.props;

const days = (await getCollection('days')).sort((a, b) =>
  a.id.localeCompare(b.id)
);
---

<nav class="sidebar" aria-label="Trip days">
  <a href={import.meta.env.BASE_URL} class="sidebar-home">
    <span class="home-icon">🗺️</span>
    <span>Overview</span>
  </a>
  <ul>
    {days.map((day) => (
      <li>
        <a
          href={`${import.meta.env.BASE_URL}days/${day.id}`}
          class:list={['day-link', { active: day.id === currentSlug }]}
          aria-current={day.id === currentSlug ? 'page' : undefined}
        >
          <span class="day-title">{day.data.title}</span>
          <span class="day-date">{day.data.date}</span>
        </a>
      </li>
    ))}
  </ul>
</nav>

<style>
  .sidebar {
    width: 260px;
    min-width: 260px;
    background: #ffffff;
    border-right: 1px solid #e8e8e8;
    padding: 1.5rem 0;
    position: sticky;
    top: 0;
    height: 100vh;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    z-index: 10;
  }
  .sidebar-home {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.25rem;
    font-weight: 600;
    color: #333;
    text-decoration: none;
    margin-bottom: 0.5rem;
    font-size: 0.95rem;
  }
  .sidebar-home:hover { color: #4e7a56; }
  ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .day-link {
    display: flex;
    flex-direction: column;
    padding: 0.6rem 1.25rem;
    text-decoration: none;
    color: #444;
    border-left: 3px solid transparent;
    transition: background 0.15s, border-color 0.15s;
  }
  .day-link:hover {
    background: #eef5f0;
    color: #111;
  }
  .day-link.active {
    border-left-color: #4e7a56;
    background: #e5f2e9;
    color: #111;
  }
  .day-title {
    font-size: 0.875rem;
    font-weight: 500;
    line-height: 1.3;
  }
  .day-date {
    font-size: 0.75rem;
    color: #888;
    margin-top: 0.1rem;
  }
  .day-link.active .day-date { color: #4e7a56; }

  @media (max-width: 768px) {
    .sidebar {
      position: fixed;
      top: calc(env(safe-area-inset-top) + 65px);
      left: 0.5rem;
      width: 270px;
      max-height: calc(100dvh - env(safe-area-inset-top) - 80px - 1rem);
      border-radius: 16px;
      box-shadow: 0 8px 40px rgba(0, 0, 0, 0.18);
      border: none;
      border-right: none;
      padding-top: 0.75rem;
      padding-bottom: 0.75rem;
      opacity: 0;
      pointer-events: none;
      transform: translateX(-20px);
      transition: opacity 0.2s ease, transform 0.2s ease;
    }
    .sidebar.open {
      opacity: 1;
      pointer-events: auto;
      transform: translateX(0);
    }
  }
</style>
