---
interface Props {
  images: { src: string; alt: string; caption?: string }[];
  columns?: 2 | 3;
}
const { images, columns = 2 } = Astro.props;
---

<div class={`image-grid cols-${columns}`}>
  {images.map((img) => (
    <figure>
      <img src={img.src} alt={img.alt} loading="lazy" />
      {img.caption && <figcaption>{img.caption}</figcaption>}
    </figure>
  ))}
</div>

<style>
  .image-grid {
    display: grid;
    gap: 1rem;
    margin: 2rem 0;
  }
  .image-grid.cols-2 { grid-template-columns: repeat(2, 1fr); }
  .image-grid.cols-3 { grid-template-columns: repeat(3, 1fr); }
  figure {
    margin: 0;
  }
  img {
    width: 100%;
    height: 220px;
    object-fit: cover;
    border-radius: 6px;
    display: block;
  }
  figcaption {
    font-size: 0.8rem;
    color: #777;
    margin-top: 0.35rem;
    text-align: center;
  }
  @media (max-width: 600px) {
    .image-grid.cols-2,
    .image-grid.cols-3 {
      grid-template-columns: 1fr;
    }
  }
</style>
