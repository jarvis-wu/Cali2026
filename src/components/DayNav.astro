---
interface DayEntry {
  id: string;
  data: { title: string };
}
interface Props {
  prev?: DayEntry;
  next?: DayEntry;
}
const { prev, next } = Astro.props;
---

<nav class="day-nav" aria-label="Day navigation">
  <div class="nav-inner">
    {prev ? (
      <a href={`/days/${prev.id}`} class="nav-link prev">
        <span class="nav-arrow">←</span>
        <span class="nav-label">
          <span class="nav-hint">Previous</span>
          <span class="nav-title">{prev.data.title}</span>
        </span>
      </a>
    ) : <div />}

    {next ? (
      <a href={`/days/${next.id}`} class="nav-link next">
        <span class="nav-label">
          <span class="nav-hint">Next</span>
          <span class="nav-title">{next.data.title}</span>
        </span>
        <span class="nav-arrow">→</span>
      </a>
    ) : <div />}
  </div>
</nav>

<style>
  .day-nav {
    border-top: 1px solid #e8e8e8;
    margin-top: 3rem;
    padding-top: 1.5rem;
    padding-bottom: 2rem;
  }
  .nav-inner {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }
  .nav-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    color: #444;
    padding: 0.75rem 1rem;
    border: 1px solid #e8e8e8;
    border-radius: 8px;
    transition: border-color 0.15s, background 0.15s;
    max-width: 48%;
  }
  .nav-link:hover {
    border-color: #e35d2b;
    background: #fff3ee;
    color: #111;
  }
  .nav-link.next { text-align: right; }
  .nav-label {
    display: flex;
    flex-direction: column;
  }
  .nav-hint {
    font-size: 0.75rem;
    color: #999;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .nav-title {
    font-size: 0.9rem;
    font-weight: 500;
    color: #222;
  }
  .nav-arrow {
    font-size: 1.25rem;
    color: #e35d2b;
    flex-shrink: 0;
  }
</style>
